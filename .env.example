# Required
DATABASE_URL=postgresql://user:password@localhost:5432/scrapapp

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-api-key>

# Azure Blob Storage
BLOB_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
BLOB_CONTAINER_NAME=scrap-images

# Azure Maps (client-side subscription key — safe to expose in mobile apps)
# Get from: Azure Portal → Azure Maps account → Authentication
EXPO_PUBLIC_AZURE_MAPS_KEY=<your-azure-maps-subscription-key>

# Optional
PORT=3000

# CORS: comma-separated list of allowed browser origins (e.g. https://app.example.com).
# Defaults to "*" (allow all). Native mobile clients are unaffected.
ALLOWED_ORIGINS=*

# API auth: shared key required on tRPC requests (sent as "Authorization: Bearer <key>").
# Leave empty to disable auth. The mobile app must send the same value via EXPO_PUBLIC_API_KEY.
API_KEY=

# Rate limiting (per client IP, fixed window). Set RATE_LIMIT_MAX=0 to disable.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Trust proxy hops for correct client IP behind ingress (e.g. Azure Container Apps).
# A hop count, "true"/"false", or a subnet. Defaults to 1.
TRUST_PROXY=1
