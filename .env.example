# Required
DATABASE_URL=postgresql://user:password@localhost:5432/scrapapp

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com
AZURE_OPENAI_API_KEY=<your-api-key>

# Azure Blob Storage
BLOB_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
BLOB_CONTAINER_NAME=scrap-images

# Optional
PORT=3000

# CORS: comma-separated list of allowed browser origins (e.g. https://app.example.com).
# Defaults to "*" (allow all). Native mobile clients are unaffected.
ALLOWED_ORIGINS=*
